# ── Database (Railway auto-provides DATABASE_URL when you add a PostgreSQL service) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Security ─────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── AI APIs ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS (comma-separated list of allowed frontend origins) ──────────────────────────
# Set to your Railway frontend URL and any custom domains
CORS_ORIGINS=https://your-frontend.up.railway.app,https://app.lminventories.co.uk

# ── Frontend URL (used in password-reset emails) ─────────────────────────────────────
APP_BASE_URL=https://app.lminventories.co.uk

# ── SMTP / Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.fasthosts.co.uk
SMTP_PORT=587
SMTP_USER=no-reply@lminventories.co.uk
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@lminventories.co.uk
SMTP_FROM_REPORTS=reports@lminventories.co.uk

# ── Address Lookup ────────────────────────────────────────────────────────────────────
IDEALPOSTCODES_API_KEY=your-idealpostcodes-key

# ── Gunicorn tuning (optional, Railway defaults are fine) ─────────────────────────────
# WEB_CONCURRENCY=2
